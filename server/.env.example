# Copy this file to .env and fill in the values

# Server port
PORT=5000

# MongoDB Atlas connection URI (leave blank to use local JSON fallback — not for production!)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/school_facility?retryWrites=true&w=majority

# JWT Secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_very_long_random_secret_key

# Allowed frontend origin (e.g. https://your-frontend.onrender.com)
# Use * only for local development
CLIENT_ORIGIN=http://localhost:3000

# Node environment
NODE_ENV=development
